      "description": "User logged in",
      "required": false
    },
    {
      "name": "add_to_cart",
      "description": "Product added to cart",
      "required": false
    }
  ],
  "timeout": {
    "script": 25000,
    "navigation": 25000,
    "pageWait": 3000,
    "total": 720000
